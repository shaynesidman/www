---
import GithubIcon from "./icons/GithubIcon.astro";
import ExternalIcon from "./icons/ExternalIcon.astro";
const { title, deploymentLink, repoLink, description, time, status, tech } = Astro.props;
---

<div class="bg-[var(--bg-primary)] flex flex-col border border-[var(--bg-secondary)] rounded-lg p-4 gap-3 transition duration-300">
    <div class="flex flex-row justify-between">
        <h2 class="text-2xl font-mono">{title}</h2>
        <div class="flex flex-row items-center gap-4">
            {deploymentLink === "" ? <></> : <a href={deploymentLink} class="rounded-lg px-2 py-1 text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] transition duration-300 border flex items-center gap-2">Live<ExternalIcon size={14} /></a>}
            {repoLink === "" ? <></> : <a href={repoLink} class="rounded-lg px-2 py-1 text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] transition duration-300 border flex items-center gap-2">Source<GithubIcon size={14} /></a>}
            <span class=`rounded-lg px-2 py-1 ${status === "Done" ? "bg-[#2dc937]" : "bg-[#cc3232]"}`>{status}</span>
            <p class="flex items-center">{time}</p>
        </div>
    </div>
    <p class="text-[var(--text-secondary)]">{description}</p>
    <div class="flex flex-row gap-2 flex-wrap">
        {tech.map((piece: string[]) => (
            <span class="rounded-lg px-2 py-1 bg-[var(--bg-secondary)] text-[var(--text-secondary)] text-sm font-mono">{piece}</span>
        ))}
    </div>
</div>

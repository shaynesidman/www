---
const { title, deploymentLink, repoLink, description, time, status, tech, dialogContent = "" } = Astro.props;
const dialogId = `dialog-${title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`;
---

<div
    class="bg-[var(--bg-primary)] flex flex-col border border-[var(--bg-secondary)] rounded-lg p-4 gap-2 cursor-pointer hover:border-[var(--text-secondary)] transition duration-300"
    onclick={`document.getElementById('${dialogId}').showModal()`}
>
    <div class="flex flex-row justify-between">
        <h2 class="text-2xl">{title}</h2>
        <div class="flex flex-row items-center gap-6">
            {deploymentLink === "" ? <></> : <a href={deploymentLink} data-stop-propagation class="rounded-lg px-2 py-1 text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition duration-300 bg-[var(--bg-secondary)]">Deployment</a>}
            {repoLink === "" ? <></> : <a href={repoLink} data-stop-propagation class="rounded-lg px-2 py-1 text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition duration-300 bg-[var(--bg-secondary)]">Source</a>}
            <span class=`rounded-lg px-2 py-1 ${status === "Done" ? "bg-[#2dc937]" : "bg-[#cc3232]"}`>{status}</span>
            <p class="flex items-center">{time}</p>
        </div>
    </div>
    <p class="text-[var(--text-secondary)]">{description}</p>
    <div class="flex flex-row gap-2 flex-wrap">
        {tech.map((piece: string[]) => (
            <span class="rounded-lg px-2 py-1 bg-[var(--bg-secondary)] text-[var(--text-secondary)]">{piece}</span>
        ))}
    </div>
</div>

<dialog
    id={dialogId}
    class="rounded-xl border border-[var(--bg-secondary)] bg-[var(--bg-primary)] text-[var(--text-primary)] p-6 w-full max-w-2xl shadow-2xl"
    onclick={`if (event.target === this) this.close()`}
>
    <div class="flex flex-col gap-4">
        <div class="flex flex-row justify-between items-center">
            <h2 class="text-2xl font-semibold">{title}</h2>
            <button
                onclick={`document.getElementById('${dialogId}').close()`}
                class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition duration-200 text-2xl leading-none"
                aria-label="Close"
            >&times;</button>
        </div>
        <div set:html={dialogContent} />
    </div>
</dialog>

<style>
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(2px);
    }
</style>

<script>
    document.querySelectorAll('[data-stop-propagation]').forEach(el => {
        el.addEventListener('click', e => e.stopPropagation());
    });
</script>

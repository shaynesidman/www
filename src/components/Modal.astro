---
import GithubIcon from "./icons/GithubIcon.astro";
import ExternalIcon from "./icons/ExternalIcon.astro";
const { id, title, deploymentLink, repoLink, status, tech, modalDescription = [], contributions = [], impact = [] } = Astro.props;
---

<dialog
    id={id}
    class="rounded-xl border border-[var(--bg-secondary)] bg-[var(--bg-primary)] text-[var(--text-primary)] p-6 w-full max-w-2xl shadow-2xl"
>
    <div class="flex flex-col gap-4">
        <div class="flex flex-row justify-between items-center">
            <h2 class="text-2xl font-semibold font-mono">{title}</h2>
            <div class="flex flex-row gap-2 ">
                <span class={`rounded-lg px-2 py-1 text-sm ${status === "Done" ? "bg-[#2dc937]" : status === "Deprecated" ? "bg-[#888]" : "bg-[#cc3232]"}`}>{status}</span>
                {deploymentLink !== "" && <a href={deploymentLink} class="rounded-lg px-2 py-1 text-sm text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] transition duration-300 border outline-none flex items-center gap-1.5">Live<ExternalIcon size={13} /></a>}
                {repoLink !== "" && <a href={repoLink} class="rounded-lg px-2 py-1 text-sm text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] transition duration-300 border outline-none flex items-center gap-1.5">Source<GithubIcon size={13} /></a>}
                <button
                    data-close-dialog={id}
                    class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition duration-200 text-2xl leading-none outline-none pl-2"
                    aria-label="Close"
                >&times;</button>
            </div>
        </div>
        {modalDescription.length > 0 && (
            <div class="space-y-2">
                <h3 class="font-mono font-semibold">Description</h3>
                {modalDescription.map((line: string) => (
                    <p>{line}</p>
                ))}
            </div>
        )}
        {contributions.length > 0 && (
            <div class="space-y-2">
                <h3 class="font-mono font-semibold">Contributions</h3>
                <ul class="list-disc list-inside space-y-1">
                    {contributions.map((contribution: string) => (
                        <li>{contribution}</li>
                    ))}
                </ul>
            </div>
        )}
        {impact.length > 0 && (
            <div class="space-y-2">
                <h3 class="font-mono font-semibold">Impact</h3>
                <ul class="list-disc list-inside space-y-1">
                    {impact.map((imp: string) => (
                        <li>{imp}</li>
                    ))}
                </ul>
            </div>
        )}
        <div class="space-y-2">
            <h3 class="font-mono font-semibold">Stack</h3>
            <div class="flex flex-row gap-2 flex-wrap">
                {tech.map((piece: string) => (
                    <span class="rounded-lg px-2 py-1 bg-[var(--bg-secondary)] text-[var(--text-secondary)] text-sm font-mono">{piece}</span>
                ))}
            </div>
        </div>

        <slot />
    </div>
</dialog>

<style>
    dialog {
        margin: auto;
    }
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(2px);
    }
</style>

<script>
    document.querySelectorAll('dialog').forEach(dialog => {
        dialog.addEventListener('click', e => {
            if (e.target === dialog) dialog.close();
        });
        dialog.addEventListener('close', () => {
            document.body.style.overflow = '';
        });
    });

    document.querySelectorAll('[data-close-dialog]').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).getAttribute('data-close-dialog');
            if (id) (document.getElementById(id) as HTMLDialogElement)?.close();
        });
    });
</script>

---
import PageLayout from "../layouts/PageLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"blog">[] = await getCollection("blog");
---
<PageLayout>
    <ul>
        {await Promise.all(
            posts.map(async (post, index) => {
                const { Content } = await post.render();
                return (
                    <li class="mb-6 pb-4 flex flex-col gap-4 text-[var(--text-secondary)] border border-[var(--bg-secondary)] rounded-lg p-6 mx-auto hover:cursor-pointer hover:bg-[var(--bg-secondary)] transition duration-300">
                        <div
                            class="w-full flex flex-col gap-2"
                            onclick={`document.getElementById('content-${index}').classList.toggle('max-h-0');
                                    document.getElementById('content-${index}').classList.toggle('max-h-[1000px]')`}
                        >
                            <div class="flex flex-row justify-between items-center">
                                <h2 class="text-2xl font-semibold text-left text-[var(--accent-primary)]">{post.data.title}</h2>
                                <h6 class="text-md text-[var(--text-primary)]">{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</h6>
                            </div>
                            <p class="text-left text-[var(--text-primary)]">{post.data.description}</p>
                        </div>
                        <div
                            id={`content-${index}`}
                            class="max-h-0 overflow-scroll transition-all duration-500 ease-in-out"
                        >
                            <Content />
                        </div>
                    </li>
                );
            })
        )}
    </ul>
</PageLayout>
